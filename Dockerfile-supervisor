    groupadd mysql && useradd -r -g mysql mysql && \
    mkdir -p /data/mysql && \
    chown -R mysql:mysql /runtime/mysql-binary /runtime/mysql-binary/logs && \
    rm -rf /var/lib/apt/lists/* && \
    java -version && bash /runtime/mysql-binary/init.sh

